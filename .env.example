# Prior Authorization AI Engine - Environment Configuration

# === LLM Configuration (FREE - Local HuggingFace Model) ===
# Model used for reasoning chain (runs locally, no API key needed)
LLM_MODEL_NAME=microsoft/phi-2
# Alternative lightweight options:
# LLM_MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0
# LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2  (needs ~14GB RAM)

# === Embeddings (FREE - Local SentenceTransformers) ===
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Database (PostgreSQL) ===
# Default: SQLite for easy local dev (no Postgres install needed)
DATABASE_URL=sqlite:///./prior_auth.db
# For Postgres: DATABASE_URL=postgresql://user:password@localhost:5432/prior_auth_db

# === FAISS Vector Store ===
FAISS_INDEX_PATH=./data/faiss_index
POLICY_DOCS_PATH=./data/policies

# === App Config ===
APP_ENV=development
LOG_LEVEL=INFO
MAX_RETRIEVED_DOCS=5
CONFIDENCE_THRESHOLD=0.65

# === FastAPI ===
API_HOST=0.0.0.0
API_PORT=8000

# === Streamlit ===
STREAMLIT_PORT=8501
